{
  "rewrites": [
    {
      "source": "/wp-json/(.*)",
      "destination": "https://cms.laforetdesigner.com/wp-json/$1"
    },
    {
      "source": "/wp-admin/(.*)",
      "destination": "https://cms.laforetdesigner.com/wp-admin/$1"
    },
    {
      "source": "/wp-content/(.*)",
      "destination": "https://cms.laforetdesigner.com/wp-content/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
